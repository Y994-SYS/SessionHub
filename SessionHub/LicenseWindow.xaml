<Window x:Class="SessionHub.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lisans Aktivasyonu" Height="450" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#FF1E1E1E" Foreground="White">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo/Başlık -->
        <TextBlock Grid.Row="0" Text="🔒 SESSIONHUB" FontSize="28" 
                  FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
        <TextBlock Grid.Row="1" Text="Lisans Aktivasyonu" FontSize="14" 
                  Foreground="#FFAAAAAA" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <!-- HWID Göster -->
        <TextBlock Grid.Row="2" Text="SİSTEMİNİZİN KODU (HWID):" 
                  FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Grid.Row="3" x:Name="txtHwid" IsReadOnly="True" 
                Background="#FF3E3E3E" Foreground="#FF007ACC" Padding="10"
                FontFamily="Consolas" FontSize="16" FontWeight="Bold" 
                HorizontalContentAlignment="Center"/>

        <Button Grid.Row="4" Content="📋 KODU KOPYALA" Margin="0,10,0,20" 
               Click="BtnCopy_Click" Padding="10,5" Background="#FF555555"/>

        <!-- Separator -->
        <Separator Grid.Row="5" Background="#FF444444" Margin="0,10"/>

        <!-- Key Giriş -->
        <TextBlock Grid.Row="6" Text="LİSANS ANAHTARINIZ:" 
                  FontWeight="Bold" Margin="0,10,0,5"/>
        <TextBox Grid.Row="6" x:Name="txtKey" Margin="0,35,0,0" Height="35"
                Background="#FF3E3E3E" Foreground="White" Padding="5"
                FontFamily="Consolas" TextChanged="TxtKey_TextChanged"/>

        <Button Grid.Row="6" x:Name="btnActivate" Content="AKTİVE ET" 
               Margin="0,80,0,0" Height="45" Click="BtnActivate_Click"
               Background="#FF007ACC" Foreground="White" FontWeight="Bold"
               IsEnabled="False"/>

        <!-- Demo -->
        <Button Grid.Row="6" Content="DEMO MODU (3 Profil Sınırı)" 
               Margin="0,135,0,0" Height="35" Click="BtnDemo_Click"
               Background="Transparent" Foreground="#FFAAAAAA" 
               BorderBrush="#FF555555"/>
    </Grid>
</Window>